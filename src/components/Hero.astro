---
import { getImage } from "astro:assets";
import herobg from "../assets/spazioquadro-officina-serramenti.jpg";

const optimizedHero = await getImage({
  src: herobg,
  format: 'webp',
  quality: 100,
  width: 1920,
});
---


<section class="hero" id="main">
<div class="hero-bg" style={`background-image: url('${optimizedHero.src}')`}></div>

  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-tag"><p>Produzione Italiana - Itri (LT) - Gruppo Gelfù - Dal 1936</p></div>
    <h1>PORTE E <em>FINESTRE</em><br>D'ECCELLENZA PER <em>AZIENDE<br></em> E PRIVATI.</h1>
    <p class="hero-sub">Serramenti top di gamma prodotti internamente a Itri. Per rivenditori e professionisti che non vogliono sorprese.</p>
    <div class="hero-actions">
      <a class="btn-primary" href="/#contatti">Diventa Rivenditore</a>
      <a class="btn-outline" href="/#prodotti">Scopri i Prodotti</a>
    </div>
  </div>
</section>

<style>
.hero {
  height:100vh; position:relative; display:flex;
  align-items:flex-end; overflow:hidden;
}
.hero-bg {
  position:absolute; inset:0;
  background-size:cover; background-position:center; filter:brightness(0.3);
}
.hero-overlay {
  position:absolute; inset:0;
  background:linear-gradient(to top, rgba(var(--rgb-black), 0.97) 0%, rgba(var(--rgb-black), 0.15) 65%, transparent 100%);
}
.hero-content {
  position:relative; z-index:2; padding: 0 80px 80px; max-width:80em;
}
.hero-tag {
  font-family:var(--font-corpo); font-size:var(--type-tag); color:var(--accent);
  letter-spacing:3px; text-transform:uppercase; margin-bottom:24px;
  display:flex; align-items:center; padding-left: 1em;
}

.hero h1 {
  font-family:var(--font-corpo);
  font-size:clamp(60px,8.5vw,128px);
  color:var(--white); line-height:1; letter-spacing:2px; margin-bottom:32px;
}
.hero h1 em { font-style:normal; color:var(--accent); }
.hero-sub {
  font-size:var(--type-body-lg); color:var(--gray-light); line-height:1.7;
  max-width:500px; margin-bottom:48px; font-weight:300;
}
.hero-actions { display:flex; gap:16px; flex-wrap:wrap; }

.hero-content > * { animation: heroFadeUp 0.9s ease both; opacity:0; }
.hero-tag     { animation-delay:0.1s; }
.hero h1      { animation-delay:0.25s; }
.hero-sub     { animation-delay:0.42s; }
.hero-actions { animation-delay:0.58s; }

@media (max-width: 900px) {
  .hero-content { padding: 0 24px 60px; }
}
</style>
