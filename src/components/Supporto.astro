<style>
.supporto-section { background:var(--white); }
.supporto-grid {
  display:grid; grid-template-columns:repeat(4,1fr); gap:2px; margin-top:60px;
}
.scard {
  padding:40px 28px; background:var(--surface-card);
  border-top:3px solid transparent;
  transition:border-color 0.3s, background 0.3s;
  position:relative; overflow:hidden;
}
.scard::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg, rgba(var(--rgb-white), 0.06) 0%, transparent 50%, rgba(var(--rgb-white), 0.02) 100%);
  opacity:0; transition:opacity 0.4s ease; pointer-events:none; z-index:1;
}
.scard:hover::before { opacity:1; }
.scard:hover {
  border-color:var(--accent); background:var(--white);
  box-shadow:0 4px 20px rgba(var(--rgb-black), 0.06);
}
.scard-icon {
  display:flex; align-items:left; justify-content:left;
  margin-bottom:24px; color:var(--accent);
}
.scard-icon svg { height: 3em; width: auto; overflow: visible; }
.scard-title { font-size:var(--type-body-md); font-weight:600; margin-bottom:10px; letter-spacing:0.3px; }
.scard-text { font-size:var(--type-small); color:var(--text-dim); line-height:1.7; }

@media (max-width: 1100px) {
  .supporto-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .supporto-grid { grid-template-columns: 1fr; }
}
</style>
