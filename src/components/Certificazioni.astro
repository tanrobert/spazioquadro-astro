<style>
.cert-grid {
  display:grid; grid-template-columns:repeat(4,1fr); gap:2px; margin-top:60px;
}
.ccard {
  padding:48px 28px; background:var(--surface-card); display:flex;
  flex-direction:column; align-items:center; gap:16px;
  transition:background 0.3s; position:relative; overflow:hidden;
}
.ccard::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg, rgba(var(--rgb-white), 0.06) 0%, transparent 50%, rgba(var(--rgb-white), 0.02) 100%);
  opacity:0; transition:opacity 0.4s ease; pointer-events:none; z-index:1;
}
.ccard:hover::before { opacity:1; }
.ccard:hover { background:var(--white); box-shadow:0 4px 20px rgba(var(--rgb-black), 0.06); }
.ccard-icon {
  display:flex; align-items:left; justify-content:left;
  margin-bottom:24px; color:var(--accent);
}
.ccard-icon svg { height: 3em; width: auto; overflow: visible; }
.ccard-title { font-size:var(--type-small); font-weight:600; letter-spacing:1px; text-transform:uppercase; }
.ccard-text { font-size:var(--type-small); color:var(--text-dim); line-height:1.6; text-align:center; }

@media (max-width: 1100px) {
  .cert-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .cert-grid { grid-template-columns: 1fr; }
}
</style>
