<section class="partner-section" id="contatti">
  <div class="partner-left">
    <div class="section-tag">Diventa Partner</div>
    <h2 class="section-title" style="color:var(--white);font-size:clamp(36px,4vw,60px)">STIAMO<br>SELEZIONANDO<br>NUOVI PARTNER.</h2>
    <p style="color:var(--gray-light);font-size:14px;line-height:1.8;font-weight:300;margin-top:16px;">Non cerchiamo semplici clienti. Cerchiamo rivenditori che sanno posizionare un prodotto, che hanno un showroom, un parco clienti, e che vogliono un fornitore con cui costruire qualcosa, non solo ordinare.</p>
    <div class="partner-vantaggi">
      <div class="vantaggio">Listino dedicato con scontistica riservata</div>
      <div class="vantaggio">Possibilità di esclusiva territoriale</div>
      <div class="vantaggio">Ufficio tecnico con risposta entro 24h</div>
      <div class="vantaggio">Kit espositivo personalizzato - investimento a recupero</div>
      <div class="vantaggio">Supporto marketing e documentazione tecnica completa</div>
      <div class="vantaggio">Formazione montatori su richiesta</div>
    </div>
  </div>
  <div class="partner-right">
    <h3>INIZIA ORA.</h3>
    <form id="partner-form" novalidate>
      <!-- Honeypot: nascosto agli utenti, visibile ai bot -->
      <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="fg-row">
        <div class="fg"><label for="azienda">Azienda *</label><input id="azienda" type="text" name="azienda" placeholder="Nome azienda" required autocomplete="organization" /></div>
        <div class="fg"><label for="referente">Referente *</label><input id="referente" type="text" name="referente" placeholder="Nome e cognome" required autocomplete="name" /></div>
      </div>
      <div class="fg-row">
        <div class="fg"><label for="telefono">Telefono</label><input id="telefono" type="tel" name="telefono" placeholder="+39 000 000 0000" autocomplete="tel" /></div>
        <div class="fg"><label for="email">Email *</label><input id="email" type="email" name="email" placeholder="email@azienda.it" required autocomplete="email" spellcheck="false" /></div>
      </div>
      <div class="fg-row">
        <div class="fg"><label for="provincia">Provincia *</label><input id="provincia" type="text" name="provincia" placeholder="ES. MI" required autocomplete="address-level2" /></div>
        <div class="fg"><label for="citta">Città *</label><input id="citta" type="text" name="citta" placeholder="Es. Milano" required autocomplete="address-level2" /></div>
      </div>
      <div class="fg"><label for="indirizzo">Indirizzo *</label><input id="indirizzo" type="text" name="indirizzo" placeholder="Via, numero civico" required autocomplete="street-address" /></div>
      <div class="fg">
        <label for="tipo">Tipo di Attività</label>
        <select id="tipo" name="tipo">
          <option value="">Seleziona…</option>
          <option>Rivenditore Serramenti</option>
          <option>Showroom</option>
          <option>Installatore</option>
          <option>Impresa Edile</option>
          <option>Architetto / Progettista</option>
        </select>
      </div>
      <div class="fg"><label for="note">Note</label><textarea id="note" name="note" placeholder="Descrivi brevemente la tua attività e zona di interesse…"></textarea></div>

      <div id="form-feedback" class="form-feedback" aria-live="polite"></div>

      <button class="form-submit" type="submit">Invia Richiesta Partnership</button>
    </form>
  </div>
</section>

<style>
.partner-section {
  display:grid; grid-template-columns:1fr 1fr;
  min-height:640px; padding:0;
}
.partner-left {
  padding:80px; background:var(--black); color:var(--white);
  display:flex; flex-direction:column; justify-content:center;
}
.partner-vantaggi { margin-top:36px; display:flex; flex-direction:column; }
.vantaggio {
  padding:18px 0; border-bottom:1px solid var(--gray-dark);
  display:flex; align-items:center; gap:14px;
  font-size:var(--type-body-sm); color:var(--gray-light); line-height:1.5;
}
.vantaggio::before {
  content:'→'; color:var(--accent); font-size:var(--type-body); flex-shrink:0;
}
.partner-right {
  padding:72px 60px; background:var(--surface-alt); display:flex;
  flex-direction:column; justify-content:center;
}
.partner-right h3 {
  font-family:var(--font-corpo); font-size:var(--type-h2);
  letter-spacing:2px; margin-bottom:28px;
}
.fg { margin-bottom:14px; }
.fg label {
  display:block; font-size:var(--type-label); font-weight:600; letter-spacing:2px;
  text-transform:uppercase; margin-bottom:6px; color:var(--text-muted);
  font-family:var(--font-corpo);
}
.fg input, .fg select, .fg textarea {
  width:100%; padding:13px 15px; border:1px solid var(--border-input);
  background:var(--white); color:var(--black); font-size:var(--type-body-sm); font-family:var(--font-corpo);
  transition:border-color 0.2s;
  -webkit-appearance:none; appearance:none; border-radius:0;
}
.fg input:focus-visible, .fg select:focus-visible, .fg textarea:focus-visible {
  outline: 2px solid var(--accent); outline-offset: 2px; border-color: var(--accent);
}
.fg textarea { height:90px; resize:vertical; }
.fg-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.form-submit {
  width:100%; background:var(--accent); color:var(--white); border:none;
  padding:17px; font-size:var(--type-caption); font-weight:600; letter-spacing:2px;
  text-transform:uppercase; cursor:pointer; font-family:var(--font-corpo);
  margin-top:6px; transition:background 0.2s;
}
.form-submit:hover { background:var(--accent-hover); }

.form-feedback {
  font-size: var(--type-small);
  padding: 10px 14px;
  border-radius: 4px;
  display: none;
}
.form-feedback.success {
  display: block;
  background: var(--border-mid);
  color: #a8e6a3;
}
.form-feedback.error {
  display: block;
  background: rgba(255,80,80,0.12);
  color: #ff9f9f;
}

@media (max-width: 900px) {
  .partner-section { grid-template-columns: 1fr; }
  .partner-left { padding:48px 24px; }
  .partner-right { padding:48px 24px; }
}
@media (max-width: 600px) {
  .fg-row { grid-template-columns: 1fr; }
}
</style>

<script>
  const form = document.getElementById('partner-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback') as HTMLElement;
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = 'Invio in corso…';
    feedback.className = 'form-feedback';
    feedback.textContent = '';

    try {
      const res = await fetch('/send.php', {
        method: 'POST',
        body: new FormData(form),
      });

      const data = await res.json();

      if (data.type === 'success') {
        feedback.className = 'form-feedback success';
        feedback.textContent = data.message ?? 'Richiesta inviata. Ti contatteremo presto.';
        form.reset();
      } else {
        feedback.className = 'form-feedback error';
        feedback.textContent = data.message ?? 'Errore nell\'invio. Riprova più tardi.';
      }
    } catch {
      feedback.className = 'form-feedback error';
      feedback.textContent = 'Errore di rete. Controlla la connessione e riprova.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Invia Richiesta Partnership';
    }
  });
</script>
