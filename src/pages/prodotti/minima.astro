<script>
(function () {
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const track = document.getElementById('minimaCarousel');
  if (!track) return;

  const prevBtn = document.querySelector('.mn-car-btn--prev');
  const nextBtn = document.querySelector('.mn-car-btn--next');
  const totalItems = track.children.length;

  let autoTimer: ReturnType<typeof setInterval> | null = null;

  function getItemWidth(): number {
    const first = track!.children[0];
    return first ? first.getBoundingClientRect().width + 12 : track!.clientWidth;
  }

  function getCurrentIndex(): number {
    return Math.round(track!.scrollLeft / getItemWidth());
  }

  function scrollToIndex(idx: number): void {
    const clamped = Math.max(0, Math.min(idx, totalItems - 1));
    track!.scrollTo({ left: clamped * getItemWidth(), behavior: 'smooth' });
  }

  function isScrollable(): boolean {
    return track!.scrollWidth > track!.clientWidth + 1;
  }

  function stepNext() {
    if (!isScrollable()) return;
    const next = (getCurrentIndex() + 1) % totalItems;
    scrollToIndex(next);
  }

  function startAuto() {
    if (prefersReduced || !isScrollable()) return;
    stopAuto();
    autoTimer = setInterval(stepNext, 4000);
  }

  function stopAuto() {
    if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
  }


  if (prevBtn) prevBtn.addEventListener('click', () => { stopAuto(); scrollToIndex(getCurrentIndex() - 1); startAuto(); });
  if (nextBtn) nextBtn.addEventListener('click', () => { stopAuto(); stepNext(); startAuto(); });

  const wrapper = document.querySelector('.mn-carousel-wrapper');
  if (wrapper) {
    wrapper.addEventListener('mouseenter', stopAuto);
    wrapper.addEventListener('mouseleave', startAuto);
    wrapper.addEventListener('focusin', stopAuto);
    wrapper.addEventListener('focusout', startAuto);
  }

  startAuto();
})();
</script>

<script is:inline>
(function () {
  var lightbox   = document.getElementById('mn-lightbox');
  var lbImg      = document.getElementById('mn-lb-img');
  var lbClose    = document.getElementById('mn-lb-close');
  var lbBackdrop = document.getElementById('mn-lb-backdrop');
  if (!lightbox || !lbImg || !lbClose || !lbBackdrop) return;

  function open(src, alt) {
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }
  function close() {
    lightbox.hidden = true;
    lbImg.src = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.mn-gal-item').forEach(function (btn) {
    btn.addEventListener('click', function () {
      open(btn.dataset.full || '', btn.dataset.alt || '');
    });
  });

  lbClose.addEventListener('click', close);
  lbBackdrop.addEventListener('click', close);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !lightbox.hidden) close();
  });
})();
</script>
