---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import ProductLayout from '../../layouts/ProductLayout.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import { getImage } from "astro:assets";
import heroImg from '../../assets/drop.png';
const optimizedHero = await getImage({ src: heroImg, format: 'webp', quality: 100, width: 1920 });
---

<Layout title="DROP UNIFORM - SPAZIO QUADRO" description="Finestra DROP UNIFORM legno-PVC a doppio vetro: estetica del legno interno, resistenza PVC esterno, alte prestazioni termiche. Per residenziale e ristrutturazione. Spazio Quadro, Itri (LT).">
  <Nav />
  <ProductLayout
    bgImage={optimizedHero.src}
    logo="/uniform.svg"
    tipo="Finestra - PVC + Legno - Doppio Vetro"
    nome="DROP UNIFORM"
    subtitle="Due materiali. Una scelta consapevole."
    paragraphs={[
      "DROP nasce dalla volontà di non dover scegliere tra prestazioni e estetica. All'interno il calore e la naturalezza del legno, che trasforma la finestra in un elemento di arredo oltre che di funzione. All'esterno la solidità e la stabilità del PVC, che non richiede manutenzione e resiste nel tempo.",
      "Il sistema a doppio vetro garantisce prestazioni termiche elevate: il legno è naturalmente isolante, il PVC aggiunge stabilità strutturale e tenuta perimetrale. Per il cliente finale significa comfort reale, bollette più basse e una classe energetica che supporta ogni pratica di riqualificazione.",
      "Per il rivenditore DROP è una proposta versatile: funziona nel residenziale moderno, nella ristrutturazione di pregio, ogni volta che il cliente vuole qualcosa di più di una finestra standard senza arrivare al prezzo del legno/alluminio puro."
    ]}
    specs={[
      { label: 'Materiale interno', value: 'Legno' },
      { label: 'Materiale esterno', value: 'PVC' },
      { label: 'Vetro', value: 'Doppio vetro camera' },
      { label: 'Prestazioni', value: 'Alte performance termiche' },
      { label: 'Versatilità', value: 'Residenziale / Ristrutturazione' },
    ]}
    detailDescription={[
      "DROP è il sistema legno-alluminio con doppio vetro camera: legno interno per il calore e la naturalezza degli ambienti, alluminio esterno per l'efficienza con doppio vetro. Un serramento che unisce due materiali e due logiche progettuali in un'unica soluzione coerente.",
      "Il doppio vetro camera garantisce prestazioni termiche elevate e un comfort acustico reale. Il legno contribuisce naturalmente all'isolamento, l'alluminio assicura tenuta e stabilità nel tempo. Una scelta consapevole per chi vuole il meglio senza rinunciare all'estetica.",
    ]}
    brochure="/brochure_drop.pdf"
  />
  <Footer />
</Layout>
